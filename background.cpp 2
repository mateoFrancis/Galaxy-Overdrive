#define PI 3.14159265358979f

class Image {
public:
    int width, height;
    unsigned char *data;
    Image() : width(0), height(0), data(NULL) {}
    ~Image() { delete [] data; }
    bool load(const char *fname) {
        char name[128]; strncpy(name, fname, 127);
        int slen = strlen(name);
        char base[128]; strncpy(base, name, slen-4); base[slen-4]='\0';
        char ppm[256];  sprintf(ppm,  "%s.ppm", base);
        char cmd[512];  sprintf(cmd,  "convert %s %s", fname, ppm);
        system(cmd);
        FILE *fp = fopen(ppm, "r");
        if (!fp) { printf("ERROR: cannot open %s\n", ppm); return false; }
        char line[200];
        fgets(line, 200, fp);
        fgets(line, 200, fp);
        while (line[0]=='#' || strlen(line)<2) fgets(line, 200, fp);
        sscanf(line, "%i %i", &width, &height);
        fgets(line, 200, fp);
        int n = width * height * 3;
        data = new unsigned char[n];
        for (int i=0; i<n; i++) data[i] = fgetc(fp);
        fclose(fp);
        unlink(ppm);
        return true;
    }
};

// Scrolls vertically (y) exactly as in the Galaxy Overdrive background.cpp
struct BgTex {
    Image   img;
    GLuint  id;
    float   xc[2], yc[2];
    bool    ok;
    BgTex() : id(0), ok(false) {
        xc[0]=0.f; xc[1]=1.f;
        yc[0]=0.f; yc[1]=1.f;
    }
    void init(const char *fname) {
        if (!img.load(fname)) return;
        glGenTextures(1, &id);
        glBindTexture(GL_TEXTURE_2D, id);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S,     GL_REPEAT);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T,     GL_REPEAT);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_NEAREST);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_NEAREST);
        glTexImage2D(GL_TEXTURE_2D, 0, 3, img.width, img.height, 0,
                     GL_RGB, GL_UNSIGNED_BYTE, img.data);
        ok = true;
    }
    void update() {          // scroll downward like background.cpp physics()
        yc[0] += 0.001f;
        yc[1] += 0.001f;
    }
    void draw(int xres, int yres) {
        if (!ok) return;
        glEnable(GL_TEXTURE_2D);
        glBindTexture(GL_TEXTURE_2D, id);
        glColor4f(1,1,1,1);
        glBegin(GL_QUADS);
            glTexCoord2f(xc[0], yc[1]); glVertex2i(0,    0);
            glTexCoord2f(xc[0], yc[0]); glVertex2i(0,    yres);
            glTexCoord2f(xc[1], yc[0]); glVertex2i(xres, yres);
            glTexCoord2f(xc[1], yc[1]); glVertex2i(xres, 0);
        glEnd();
        glDisable(GL_TEXTURE_2D);
    }
} bg;

