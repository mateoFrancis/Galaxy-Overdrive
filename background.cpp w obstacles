// ---------------------------------------------------------------------------
// main
// ---------------------------------------------------------------------------
int main()
{
    init_opengl();
    obstaclesInit();    // seed + spawn all obstacles

    int done = 0;
    struct timespec t0, t1;
    clock_gettime(CLOCK_MONOTONIC, &t0);
    int nframes = 0;
    time_t secTimer = time(NULL);

    while (!done) {
        while (x11.getXPending()) {
            XEvent e = x11.getXNextEvent();
            x11.check_resize(&e);
            check_mouse(&e);
            done = check_keys(&e);
        }

        clock_gettime(CLOCK_MONOTONIC, &t1);
        float dt = (t1.tv_sec - t0.tv_sec) + (t1.tv_nsec - t0.tv_nsec) * 1e-9f;
        t0 = t1;
        if (dt > 0.05f) dt = 0.05f;   // clamp for slow frames
        g_time += dt;

        physics(dt);
        render();

        ++nframes;
        time_t now = time(NULL);
        if (now > secTimer) {
            secTimer = now;
            g.fps = nframes;
            nframes = 0;
        }

        x11.swapBuffers();
        usleep(200);
    }

    x11.cleanupXWindows();
    return 0;
}

